RESIN_ADMIN_TOKEN=change-me-admin-token
RESIN_PROXY_TOKEN=change-me-proxy-token
RESIN_AUTH_VERSION=V1

RESIN_LISTEN_ADDRESS=0.0.0.0
RESIN_PORT=2260

# Deployment profile:
# STANDARD  = full SOCKS5 inbound (CONNECT + UDP ASSOCIATE), typical VPS/bare metal
# KOYEB_TCP = TCP-only SOCKS5 inbound (CONNECT only), for TCP-only runtimes such as Koyeb
RESIN_DEPLOYMENT_PROFILE=STANDARD

# Optional SOCKS5 inbound. Set to 0 to disable.
RESIN_SOCKS5_PORT=0
# Recommended when using UDP ASSOCIATE, NAT, containers, or port mapping.
RESIN_SOCKS5_ADVERTISE_HOST=